# Copy this file to `.env` and set ONE provider. Optional — without any LLM the
# bot still answers from the best-matching Q&A in the knowledge base.
#
# Pick a provider with LLM_PROVIDER, then set that provider's key/model.

# ── ChatGPT (OpenAI) — key from platform.openai.com/api-keys ──────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini          # or gpt-4o, gpt-4.1-mini

# ── Claude (Anthropic) — key from console.anthropic.com/settings/keys ─────────
# Uses Anthropic's OpenAI-compatible endpoint (no extra setup).
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest   # or claude-3-5-sonnet-latest

# ── Option A: Ollama — FREE, fully local, no API key ─────────────────────────
# Install from https://ollama.com/download, then:  ollama pull llama3.2:1b
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2:1b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Option B: Groq — free tier, very fast (key from console.groq.com/keys) ────
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Option C: Google Gemini — generous free tier (aistudio.google.com/apikey) ─
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# ── Option D: OpenRouter — free models (openrouter.ai/keys) ───────────────────
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Generation knobs (optional; these are the defaults)
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=450
